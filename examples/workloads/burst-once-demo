#!/usr/bin/env bash
set -euo pipefail
printf 'burst-once-demo starting\n'
printf 'viewer hints: type RARE_MATCH, checkpoint, cache, or loader\n'
for i in $(seq 1 2500); do
  if (( i == 1777 )); then
    printf 'RARE_MATCH incident id=%04d component=cache message="needle in large haystack" severity=high\n' "$i"
  elif (( i % 233 == 0 )); then
    printf 'WARN checkpoint id=%04d component=loader progress=%d%%\n' "$i" $((i * 100 / 2500))
  else
    printf 'DEBUG filler id=%04d component=loader value=%08x\n' "$i" "$i"
  fi
done
printf 'burst-once-demo complete lines=2500\n'

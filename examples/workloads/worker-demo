#!/usr/bin/env bash
set -euo pipefail
printf 'worker-demo starting pid=%s\n' "$$"
printf 'viewer hints: type reconcile, drift, warning, queue, or complete\n'
i=0
while :; do
  i=$((i + 1))
  printf 'INFO worker heartbeat job=%04d queue=default state=running\n' "$i"
  if (( i % 3 == 0 )); then
    printf 'WARN reconcile drift job=%04d expected=%d actual=%d\n' "$i" $((5000+i)) $((4997+i))
  fi
  if (( i % 8 == 0 )); then
    printf 'INFO worker complete job=%04d duration=%ds\n' "$i" $((5 + (i % 10)))
  fi
  sleep 2
done

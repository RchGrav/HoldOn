#!/usr/bin/env bash
set -euo pipefail
printf 'import-once-demo starting\n'
printf 'viewer hints: type ERROR, WARN, duplicate, email, or complete\n'
for i in $(seq 1 90); do
  case $((i % 10)) in
    0) printf 'ERROR import row=%03d failed validation field=email value=user-%03d.example.com\n' "$i" "$i" ;;
    3) printf 'WARN import row=%03d duplicate customer ignored key=demo-%03d\n' "$i" "$i" ;;
    6) printf 'WARN import row=%03d slow enrichment provider=geoip duration=%dms\n' "$i" $((300+i)) ;;
    *) printf 'INFO import row=%03d accepted customer=demo-%03d\n' "$i" "$i" ;;
  esac
done
printf 'import-once-demo complete accepted=63 warn=18 error=9\n'

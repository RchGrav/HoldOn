#!/usr/bin/env bash
set -euo pipefail
printf 'web-api-demo starting pid=%s\n' "$$"
printf 'pretending to serve http://127.0.0.1:8080\n'
printf 'viewer hints: type error, timeout, db, payment, auth, or latency\n'
i=0
while :; do
  i=$((i + 1))
  printf 'INFO api request id=%04d method=GET path=/v1/items status=200 latency=%dms\n' "$i" $((18 + (i % 53)))
  if (( i % 4 == 0 )); then
    printf 'WARN db retry request=%04d database connection timeout retry=%d\n' "$i" $((i / 4))
  fi
  if (( i % 7 == 0 )); then
    printf 'ERROR payment request=%04d gateway=stripe outcome=declined reason=card_expired\n' "$i"
  fi
  if (( i % 11 == 0 )); then
    printf 'WARN auth request=%04d token refresh took %dms\n' "$i" $((200 + i))
  fi
  sleep 1
done
